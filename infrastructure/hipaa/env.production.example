# EDON HIPAA production environment template.
# Values are examples/placeholders. Do not commit real secrets.

EDON_ENV=production
ENVIRONMENT=production
EDON_AUTH_ENABLED=true
EDON_ENTERPRISE_MODE=true
EDON_ENTERPRISE_SSO_ONLY=true
EDON_CREDENTIALS_STRICT=true
EDON_TOKEN_BINDING_ENABLED=true
EDON_RATE_LIMIT_ENABLED=true
EDON_ENCRYPT_AUDIT_PAYLOAD=true
EDON_ALLOW_ENV_TOKEN_IN_PROD=false

EDON_CLOUD_PROVIDER=azure
EDON_HIPAA_DEPLOYMENT_PROFILE=true
EDON_BAA_SIGNED=true
EDON_PRIVATE_NETWORK_ENABLED=true
EDON_WAF_ENABLED=true
EDON_MANAGED_POSTGRES=true

DATABASE_URL=postgresql://edon:<from-vault>@<managed-postgres-host>:5432/edon
EDON_API_TOKEN=<from-vault>
EDON_DB_ENCRYPTION_KEY=<from-vault>
EDON_SIGNING_KEY_HEX=<from-kms-or-vault>
EDON_AUDIT_CHAIN_SIGNING_KEY=<from-kms-or-vault>
EDON_EDGE_BUNDLE_SIGNING_KEY=<from-kms-or-vault>

AZURE_KEY_VAULT_URL=https://<vault-name>.vault.azure.net/
AZURE_KEY_VAULT_KEY_ID=https://<vault-name>.vault.azure.net/keys/<key-name>/<version>
# AWS alternative:
# AWS_SECRETS_MANAGER_REGION=us-east-1
# AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/...
# GCP alternative:
# GCP_SECRET_MANAGER_PROJECT=<project-id>
# GCP_KMS_KEY_NAME=projects/<project>/locations/<region>/keyRings/<ring>/cryptoKeys/<key>

CLERK_SECRET_KEY=<from-vault>
CLERK_ISSUER=https://<issuer>
CLERK_AUDIENCE=edon-console
EDON_ENTERPRISE_IDENTITY_PROVIDERS=entra,oidc,saml
EDON_SSO_ROLE_CLAIM=edon_role
EDON_SSO_DEPARTMENT_CLAIM=edon_department

EDON_INVITE_EMAIL_ENABLED=true
EDON_SMTP_HOST=<smtp-host>
EDON_SMTP_PORT=587
EDON_SMTP_USERNAME=<from-vault>
EDON_SMTP_PASSWORD=<from-vault>
EDON_SMTP_FROM=no-reply@hospital.example

EDON_METRICS_ENABLED=true
EDON_ALERT_WEBHOOK=<from-vault>
EDON_LOG_RETENTION_DAYS=2190
EDON_SENTINEL_WORKSPACE_ID=<workspace-id>
# SIEM alternatives:
# EDON_SIEM_ENDPOINT=https://siem.example/ingest
# EDON_SPLUNK_HEC_URL=https://splunk.example/services/collector
# EDON_LOG_ARCHIVE_BUCKET=<bucket-or-container>

EDON_BACKUP_BUCKET=<backup-container-or-bucket>
EDON_BACKUP_SCHEDULE=0 3 * * *
EDON_RESTORE_DRILL_LAST_RUN_AT=2026-05-21T00:00:00Z

EDON_CORS_ORIGINS=https://console.hospital.example
EDON_REQUIRE_ADMIN_MFA=true
EDON_REQUIRE_PHISHING_RESISTANT_MFA=true
EDON_EDGE_REQUIRE_NODE_CERTIFICATE=true
EDON_EDGE_REQUIRE_ATTESTATION=true
