# EDON Gateway - Environment Configuration
# Copy this file to .env and update with your values
# This .env file is gateway-specific (Option B: stricter isolation)
#
# Fly.io: fly.toml sets ENVIRONMENT=production and EDON_CORS_ORIGINS. Set secrets with:
#   fly secrets set STRIPE_SECRET_KEY=sk_live_... STRIPE_WEBHOOK_SECRET=whsec_...
#   fly secrets set CLERK_SECRET_KEY=sk_live_... EDON_API_TOKEN=<secure-token>
#   (optional) fly secrets set EDON_CREDENTIALS_STRICT=true EDON_ALLOW_ENV_TOKEN_IN_PROD=false

# ============================================
# 100 systems preset (production scale)
# ============================================
# Uncomment and set to run at 100 systems / 20M decisions per day:
# DATABASE_URL=postgresql://user:password@host:5432/edon
# EDON_WORKERS=4

# ============================================
# Production lock (recommended for prod)
# ============================================
# Fail closed on missing credentials
EDON_CREDENTIALS_STRICT=true
# Enforce token binding (agent -> token)
EDON_TOKEN_BINDING_ENABLED=true
# Never allow env token auth in production
EDON_ALLOW_ENV_TOKEN_IN_PROD=false
# Require strict validation
EDON_VALIDATE_STRICT=true
# Enable rate limiting
EDON_RATE_LIMIT_ENABLED=true
# Restrict CORS to explicit origins in prod (no wildcard). Must include console domain for Agent UI.
EDON_CORS_ORIGINS=https://edoncore.com,https://www.edoncore.com,https://console.edoncore.com

# ============================================
# Dev defaults (safe for local; change for production)
# ============================================
EDON_AUTH_ENABLED=true
EDON_API_TOKEN=change-me
EDON_CREDENTIALS_STRICT=false
EDON_CORS_ORIGINS=http://localhost:5173
EDON_DB_URL=sqlite:///./edon.db

# ============================================
# Authentication & Security
# ============================================
# (Dev defaults above; override for production.)

# Enable token binding to agent IDs (recommended)
EDON_TOKEN_BINDING_ENABLED=false

# ============================================
# Credentials & Security
# ============================================

# Strict mode: Fail closed if credentials not in database (REQUIRED for production)
EDON_CREDENTIALS_STRICT=true

# Token hardening: Never expose tokens to agents (recommended)
EDON_TOKEN_HARDENING=true

# Network gating: Restrict access to external services (optional)
EDON_NETWORK_GATING=false

# ============================================
# Validation & Input
# ============================================

# Strict validation: Reject invalid input instead of sanitizing (recommended)
EDON_VALIDATE_STRICT=true

# ============================================
# Clawdbot Gateway (if using)
# ============================================

# Clawdbot Gateway URL (if running locally)
CLAWDBOT_GATEWAY_URL=http://127.0.0.1:18789

# Clawdbot Gateway token (store in database via /credentials/set in production)
CLAWDBOT_GATEWAY_TOKEN=

# ============================================
# Super-Agent Integrations (all services)
# ============================================

# Telegram bot connection (edonbot)
TELEGRAM_BOT_TOKEN=
EDON_TELEGRAM_BOT_SECRET=

# Connect page base URL (used for Gmail/Calendar OAuth redirects)
EDON_CONNECT_BASE_URL=https://your-gateway.example.com

# Google OAuth (Gmail + Google Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Brave Search
BRAVE_SEARCH_API_KEY=

# Gemini (image + voice)
GEMINI_API_KEY=

# GitHub
GITHUB_TOKEN=

# Market data / news
POLYGON_API_KEY=
FMP_API_KEY=
NEWSAPI_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Optional dev tokens (fallback if not stored in DB)
GMAIL_ACCESS_TOKEN=
GMAIL_REFRESH_TOKEN=
GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token
GMAIL_EXPIRES_AT=

GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_CALENDAR_EXPIRES_AT=

# ============================================
# Database & encryption
# ============================================

# REQUIRED in production (Fly.io). Fernet key for encrypting sensitive DB columns (credentials, etc.).
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store in secrets; if unset in production, gateway raises RuntimeError on startup.
# Use double quotes so trailing "=" in the key is preserved (e.g. ...xyz==).
# EDON_DB_ENCRYPTION_KEY="<base64-fernet-key>"

# For 100 systems / 20M decisions per day: use Postgres (set DATABASE_URL).
# Omit DATABASE_URL to use SQLite (dev only; single-writer, not for 500+ req/s).
# DATABASE_URL=postgresql://user:password@localhost:5432/edon

# Database file path (SQLite; ignored when DATABASE_URL is set)
EDON_DATABASE_PATH=edon_gateway.db

# ============================================
# Logging
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
EDON_LOG_LEVEL=INFO

# Enable structured JSON logging (recommended for production)
EDON_JSON_LOGGING=true

# ============================================
# Monitoring
# ============================================

# Enable metrics endpoint
EDON_METRICS_ENABLED=true

# Prometheus metrics port (if using Prometheus)
EDON_METRICS_PORT=9090

# ============================================
# Rate Limiting
# ============================================

# Enable rate limiting
EDON_RATE_LIMIT_ENABLED=true

# Max actions per minute per agent
EDON_RATE_LIMIT_PER_MINUTE=60

# Max actions per hour per agent
EDON_RATE_LIMIT_PER_HOUR=1000

# ============================================
# CORS (for production, restrict origins)
# ============================================

# CORS allowed origins (comma-separated, * for all)
EDON_CORS_ORIGINS=*

# ============================================
# Server
# ============================================

# Server host
EDON_HOST=0.0.0.0

# Server port
EDON_PORT=8000

# Workers (for production: 4–8 for 100 systems / 20M decisions per day)
EDON_WORKERS=1
# EDON_WORKERS=4

# ============================================
# Stripe Billing
# ============================================

# Per-decision pricing (USD per governed decision). E.g. 0.00001 = $0.00001 (1/1000 cent)
# Used for usage-based / FedEx-style billing. See docs/BILLING_PER_DECISION.md
# EDON_PRICE_PER_DECISION_USD=0.00001

# Stripe Secret Key (from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create recurring prices in Stripe for each tier, then paste IDs here
# Starter $49/mo, Growth $199/mo, Business $499/mo. See docs/STRIPE_LIVE_SETUP.md
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_BUSINESS=price_...

# Optional: Payment Links for instant redirect (no gateway call). Create in Stripe Dashboard.
# Set each link's "After payment" redirect to https://edoncore.com/account/billing?payment=success
# STRIPE_PAYMENT_LINK_STARTER=https://buy.stripe.com/...
# STRIPE_PAYMENT_LINK_GROWTH=https://buy.stripe.com/...
# STRIPE_PAYMENT_LINK_BUSINESS=https://buy.stripe.com/...
