{
  "name": "@edon/sdk",
  "version": "0.2.0",
  "description": "EDON runtime governance SDK — govern every AI agent action in real time",
  "author": "EDON <hello@edoncore.com>",
  "license": "MIT",
  "homepage": "https://edoncore.com",
  "repository": { "type": "git", "url": "https://github.com/edon-ai/edon-sdk" },
  "keywords": ["ai", "agents", "governance", "hipaa", "compliance", "llm"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.4.11"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts", "**/*.test.ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.+)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "module": "CommonJS",
          "moduleResolution": "node"
        }
      }]
    }
  }
}
